{
  "name": "@a5c-ai/compendium",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./codex": {
      "types": "./dist/codex.d.ts",
      "import": "./dist/codex.js",
      "require": "./dist/codex.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js",
      "require": "./dist/tokens.cjs"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js",
      "require": "./dist/icons.cjs"
    },
    "./css": "./dist/tokens.css",
    "./css/*": "./dist/*.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@changesets/cli": "^2.27.0",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^8.6.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "chromatic": "^16.6.0",
    "http-server": "^14.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.6.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "vite build && tsc --emitDeclarationOnly --declaration --declarationDir dist",
    "build-storybook": "storybook build",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest",
    "test:ci": "vitest run",
    "test:a11y": "playwright test",
    "playwright:install": "playwright install --with-deps chromium",
    "validate:package": "node ./scripts/validate-package.mjs",
    "validate:consumer": "node ./scripts/validate-consumer.mjs",
    "validate": "npm run lint && npm run test:ci && npm run build && npm run build-storybook && npm run validate:package && npm run validate:consumer && npm run test:a11y",
    "validate:release": "npm run validate",
    "chromatic": "chromatic --only-changed",
    "prepublishOnly": "npm run build && npm run validate:package && npm run validate:consumer",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.2"
  }
}
